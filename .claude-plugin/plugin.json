{
  "name": "codex-orchestrator",
  "displayName": "Codex Orchestrator",
  "version": "1.5.1",
  "description": "Orchestrate OpenAI Codex from Claude: delegate implementation work in supervised checkpoint slices with server-enforced quality gates, persistent plans/hypotheses, worktree isolation and per-task model/effort control.",
  "author": {
    "name": "Tom Werner",
    "url": "https://github.com/tomtastisch"
  },
  "homepage": "https://github.com/tomtastisch/codex-orchestrator",
  "repository": "https://github.com/tomtastisch/codex-orchestrator",
  "license": "MIT",
  "keywords": ["codex", "orchestration", "mcp", "delegation", "multi-agent"],
  "mcpServers": {
    "codex-orchestrator": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/bundle/server.mjs"],
      "env": {
        "ORCH_HOME": "${CLAUDE_PROJECT_DIR}/.orchestrator"
      }
    }
  }
}
